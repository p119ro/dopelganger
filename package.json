{
  "name": "doppelganger",
  "version": "1.0.0",
  "description": "Habit tracking app with multiplayer teams and battle system",
  "main": "server/server.js",
  "scripts": {
    "dev": "nodemon server/server.js",
    "start": "node server/server.js",
    "db:generate": "prisma generate --schema=server/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=server/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=server/prisma/schema.prisma",
    "db:seed": "node server/prisma/seed.js",
    "db:studio": "prisma studio --schema=server/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "socket.io": "^4.7.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
