# Server
NODE_ENV=development
PORT=3000

# Database (for Neon: both vars are the same connection string with ?sslmode=require)
# For local Docker: DATABASE_URL=postgresql://doppelganger:doppelganger@localhost:5432/doppelganger
DATABASE_URL=postgresql://doppelganger:doppelganger@localhost:5432/doppelganger
DIRECT_URL=postgresql://doppelganger:doppelganger@localhost:5432/doppelganger

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-64-char-secret
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000
